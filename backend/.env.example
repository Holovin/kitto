# Production-oriented example for a single-process PM2 deployment.
# For local development, switch PORT to 8787 and FRONTEND_ORIGIN to http://localhost:5555.
PORT=8888
FRONTEND_ORIGIN=https://your-domain.example
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
LOG_LEVEL=info
PROMPT_IO_LOG=false
OPENAI_REQUEST_TIMEOUT_MS=180000
STREAM_IDLE_TIMEOUT_MS=60000
# Keep dependent limits compatible: model prompts must fit committed source,
# invalid draft, user prompt, and repair overhead; request/output byte limits
# must be large enough for the source cap.
LLM_USER_PROMPT_MAX_CHARS=4096
CURRENT_SOURCE_EMERGENCY_MAX_CHARS=80000
LLM_MODEL_PROMPT_MAX_CHARS=180000
LLM_REQUEST_MAX_BYTES=1200000
LLM_OUTPUT_MAX_BYTES=300000
LLM_MAX_REPAIR_ATTEMPTS=2
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_MS=60000
REQUEST_BODY_LIMIT_BYTES=1200000
