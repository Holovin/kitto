# Production-oriented example for a single-process PM2 deployment.
# For local development, switch PORT to 8787 and FRONTEND_ORIGIN to http://localhost:5555.
PORT=8888
FRONTEND_ORIGIN=https://your-domain.example
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
LOG_LEVEL=info
PROMPT_IO_LOG=false
OPENAI_REQUEST_TIMEOUT_MS=120000
LLM_CHAT_HISTORY_MAX_ITEMS=40
LLM_USER_PROMPT_MAX_CHARS=4096
LLM_MODEL_PROMPT_MAX_CHARS=50000
LLM_REQUEST_MAX_BYTES=300000
LLM_OUTPUT_MAX_BYTES=100000
LLM_RATE_LIMIT_MAX_ENTRIES=10000
LLM_RATE_LIMIT_MAX_REQUESTS=60
LLM_RATE_LIMIT_WINDOW_MS=60000
