{
  "name": "backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm --prefix .. run build --workspace @kitto-openui/shared",
    "dev": "tsx watch src/index.ts",
    "prebuild": "npm --prefix .. run build --workspace @kitto-openui/shared",
    "build": "tsc -p tsconfig.json",
    "prelint": "npm --prefix .. run build --workspace @kitto-openui/shared",
    "lint": "tsc --noEmit -p tsconfig.json",
    "pretest": "npm --prefix .. run build --workspace @kitto-openui/shared",
    "test": "vitest run",
    "test:watch": "vitest",
    "prestart": "npm --prefix .. run build --workspace @kitto-openui/shared",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@kitto-openui/shared": "file:../shared",
    "@hono/node-server": "^1.19.13",
    "@openuidev/lang-core": "^0.2.1",
    "dotenv": "^17.4.1",
    "hono": "^4.12.12",
    "openai": "^6.34.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.4"
  }
}
